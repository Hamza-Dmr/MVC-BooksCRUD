@model List<MVC_BooksCRUD.Models.Book>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

<form method="get" asp-action="Index" class="row mb-4">

    <div class="col-md-4">
        <input type="text"
               name="search"
               value="@ViewBag.Search"
               class="form-control"
               placeholder="Kitap ara..." />
    </div>

    <div class="col-md-3">
        <select name="categoryId" class="form-control">

            <option value="0">Tüm Kategoriler</option>

            @foreach (var cat in ViewBag.Categories)
            {
                if (ViewBag.SelectedCategory == cat.Id)
                {
                    <option value="@cat.Id" selected>
                        @cat.Name
                    </option>
                }
                else
                {
                    <option value="@cat.Id">
                        @cat.Name
                    </option>
                }
            }

        </select>
    </div>

    <div class="col-md-3">
        <select name="sortOrder" class="form-control">

            <option value="">Sıralama Seç</option>

            <option value="title_asc"
                    selected="@(ViewBag.SortOrder == "title_asc")">
                Başlık A-Z
            </option>

            <option value="title_desc"
                    selected="@(ViewBag.SortOrder == "title_desc")">
                Başlık Z-A
            </option>

            <option value="price_asc"
                    selected="@(ViewBag.SortOrder == "price_asc")">
                Fiyat Artan
            </option>

            <option value="price_desc"
                    selected="@(ViewBag.SortOrder == "price_desc")">
                Fiyat Azalan
            </option>

        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">
            Uygula
        </button>
    </div>

</form>

<a asp-action="Add" class="btn btn-success mb-3">
    + Yeni Kitap Ekle
</a>

<table class="table table-striped table-bordered">

    <thead>
        <tr>
            <th>Başlık</th>
            <th>Yazar</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>Kategori</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Title</td>

                <td>@item.Author</td>

                <td>@item.Price</td>

                <td>@item.Stock</td>

                <td>@item.Category?.Name</td>

                <td>

                    <a asp-action="Update"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Güncelle
                    </a>

                    <a asp-action="Remove"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Sil
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>